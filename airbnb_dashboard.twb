    <dashboard name='Airbnb Pricing Story' type='storyboard'>
      <layout-options>
        <title>
          <formatted-text>
            <run bold='true' fontsize='8'>&lt;Sheet Name&gt;</run>
          </formatted-text>
        </title>
      </layout-options>
      <style />
      <size maxheight='1000' maxwidth='1350' minheight='1000' minwidth='1350' sizing-mode='fixed' />
      <zones>
        <zone h='100000' id='2' type-v2='layout-basic' w='100000' x='0' y='0'>
          <zone h='98400' id='1' param='vert' removable='false' type-v2='layout-flow' w='98814' x='593' y='800'>
            <zone h='2200' id='3' type-v2='title' w='98814' x='593' y='800' />
            <zone h='10100' id='4' is-fixed='true' paired-zone-id='5' removable='false' type-v2='flipboard-nav' w='98814' x='593' y='3000' />
            <zone h='86100' id='5' paired-zone-id='4' removable='false' type-v2='flipboard' w='98814' x='593' y='13100'>
              <flipboard active-id='2' nav-type='caption' show-nav-arrows='true'>
                <story-points>
                  <story-point caption='Room type is a major pricing driver, with Entire place listings generally positioned at higher price levels than other room types.&#10;&#10;' captured-sheet='Listings Count and Average Price by Room Type' id='2' />
                  <story-point caption='Neighbourhood strongly influences price, so location-based benchmarking is essential for realistic pricing decisions.&#10;&#10;' captured-sheet='Avg Price by Neighbourhood and Room Type' id='3' />
                  <story-point caption='Bedrooms have a positive but uneven relationship with price, meaning size matters but does not determine value on its own.&#10;&#10;&#10;Bedrooms have a positive but uneven relationship with price, meaning size matters but does not determine value on its own.' captured-sheet='Relationship Between Bedrooms and Price' id='4' />
                  <story-point caption='The analysis suggests that effective pricing should be based on room type, neighbourhood, and comparable market segments rather than on a single city-wide average.&#10;&#10;' captured-sheet='Airbnb Pricing by Neighbourhood and Room Type' id='5' />
                </story-points>
              </flipboard>
            </zone>
          </zone>
          <zone-style>
            <format attr='border-color' value='#000000' />
            <format attr='border-style' value='none' />
            <format attr='border-width' value='0' />
            <format attr='margin' value='8' />
          </zone-style>
        </zone>
      </zones>
      <simple-id uuid='{67545249-32E0-495D-A2C1-B94B2FB58EFB}' />
    </dashboard>
